# EliteScore frontend — environment variables
# Copy to `.env.local` and add values from the Supabase project (Settings → API).
# Never commit `.env.local`. Never add the service role key to `NEXT_PUBLIC_*`.

# Required for proof file uploads (browser → Supabase Storage bucket `proofs`).
# Vercel: Project → Environment Variables (Production + Preview). No trailing spaces.
# After add/change, trigger a new deployment so the client bundle includes these values.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_public_key

# Optional: browser console logs for proof file upload (prefix "[proof-upload]"). On in development by default; set 1 to debug on Vercel.
# NEXT_PUBLIC_DEBUG_PROOF_UPLOAD=1
