CREATE TABLE public.challenge_roadmap_steps (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  challenge_template_id uuid NOT NULL,
  week integer,
  day integer NOT NULL CHECK (day >= 1),
  title text NOT NULL,
  instructions text NOT NULL,
  expected_proof text,
  step_type text CHECK (step_type IS NULL OR (step_type = ANY (ARRAY['learn'::text, 'practice'::text, 'project'::text, 'review'::text]))),
  resource_link text,
  resource_start_seconds integer CHECK (resource_start_seconds IS NULL OR resource_start_seconds >= 0),
  resource_end_seconds integer CHECK (resource_end_seconds IS NULL OR resource_end_seconds >= 0),
  proof_type_required text CHECK (proof_type_required IS NULL OR (proof_type_required = ANY (ARRAY['image'::text, 'link'::text, 'text'::text, 'video'::text, 'mixed'::text]))),
  requires_proof boolean NOT NULL DEFAULT true,
  submission_requirements text,
  reward_xp integer NOT NULL DEFAULT 0 CHECK (reward_xp >= 0),
  reward_elite_score integer NOT NULL DEFAULT 0 CHECK (reward_elite_score >= 0),
  sort_order integer,
  CONSTRAINT challenge_roadmap_steps_pkey PRIMARY KEY (id),
  CONSTRAINT challenge_roadmap_steps_challenge_template_id_fkey FOREIGN KEY (challenge_template_id) REFERENCES public.challenge_templates(id)
);
CREATE TABLE public.challenge_templates (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  name text NOT NULL,
  track text NOT NULL,
  difficulty integer NOT NULL CHECK (difficulty >= 1 AND difficulty <= 5),
  description text NOT NULL,
  daily_requirement text NOT NULL,
  proof_type_required text NOT NULL CHECK (proof_type_required = ANY (ARRAY['image'::text, 'link'::text, 'text'::text, 'video'::text, 'mixed'::text])),
  failure_condition text NOT NULL,
  duration_days integer NOT NULL CHECK (duration_days >= 1),
  base_reward_xp integer NOT NULL CHECK (base_reward_xp >= 0),
  completion_rate_cached numeric CHECK (completion_rate_cached IS NULL OR completion_rate_cached >= 0::numeric AND completion_rate_cached <= 100::numeric),
  is_active boolean NOT NULL DEFAULT true,
  created_at timestamp with time zone NOT NULL DEFAULT now(),
  skills_youll_learn jsonb NOT NULL DEFAULT '[]'::jsonb CHECK (jsonb_typeof(skills_youll_learn) = 'array'::text),
  before_you_begin text,
  resource_links jsonb NOT NULL DEFAULT '[]'::jsonb CHECK (jsonb_typeof(resource_links) = 'array'::text),
  daily_reward_elite_score integer NOT NULL DEFAULT 15,
  missed_day_penalty integer NOT NULL DEFAULT '-8'::integer,
  max_missed_days integer NOT NULL DEFAULT 3,
  fail_penalty integer NOT NULL DEFAULT '-35'::integer,
  quit_penalty integer NOT NULL DEFAULT '-35'::integer,
  completion_bonus integer NOT NULL DEFAULT 40,
  CONSTRAINT challenge_templates_pkey PRIMARY KEY (id)
);
CREATE TABLE public.leaderboard_rows (
